<Window x:Class="CodexSwitcher.Bootstrapper.ProfilePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로필 팝업"
        Width="176"
        Height="60"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="SkyCirclePopupButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FFE0F2FE" />
            <Setter Property="BorderBrush" Value="#FF7DD3FC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4"
                                                  Color="#FF0369A1"
                                                  Direction="270"
                                                  Opacity="0.18"
                                                  RenderingBias="Performance"
                                                  ShadowDepth="1" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFBAE6FD" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF38BDF8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF7DD3FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CoralSquareButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FFFFD6CC" />
            <Setter Property="BorderBrush" Value="#FFFF8A6A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFFB9A8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFFF6F4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFF967D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="2">
        <Border x:Name="PopupSurface"
                Padding="6,3"
                Background="{DynamicResource AppBrush.Surface}"
                BorderBrush="{DynamicResource AppBrush.Border}"
                BorderThickness="1"
                CornerRadius="7"
                MouseLeftButtonDown="PopupSurface_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6"
                                  Color="#FF0F172A"
                                  Direction="270"
                                  Opacity="0.11"
                                  RenderingBias="Performance"
                                  ShadowDepth="1" />
            </Border.Effect>
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           FontSize="10.5"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppBrush.Text}"
                           Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button AutomationProperties.Name="팝업 최소화"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource CoralSquareButtonStyle}" />
                    <Button Margin="4,0,0,0"
                            AutomationProperties.Name="메인 창으로 돌아가기"
                            Click="ReturnButton_Click"
                            Style="{StaticResource SkyCirclePopupButtonStyle}" />
                </StackPanel>

                <Grid Grid.Row="0"
                      Grid.Column="1"
                      Margin="4,0,0,0"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="PercentCol" />
                        <ColumnDefinition Width="*" SharedSizeGroup="ValueCol" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="9.6"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="5시간" />
                    <TextBlock Grid.Column="1"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="10.0"
                               FontWeight="Bold"
                               Foreground="{Binding FiveHourUsage.ProgressBrush}"
                               Text="{Binding FiveHourUsage.RemainingPercent, StringFormat={}{0}%}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="10.0"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="--">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="9.2"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="{Binding FiveHourUsage.PopupResetText}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <Grid Grid.Row="1"
                      Grid.Column="1"
                      Margin="4,0,0,0"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="PercentCol" />
                        <ColumnDefinition Width="*" SharedSizeGroup="ValueCol" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="9.6"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="주간" />
                    <TextBlock Grid.Column="1"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="10.0"
                               FontWeight="Bold"
                               Foreground="{Binding WeeklyUsage.ProgressBrush}"
                               Text="{Binding WeeklyUsage.RemainingPercent, StringFormat={}{0}%}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               FontSize="10.0"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="--">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="9.2"
                               Foreground="{DynamicResource AppBrush.TextMuted}"
                               Text="{Binding WeeklyUsage.PopupResetText}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
