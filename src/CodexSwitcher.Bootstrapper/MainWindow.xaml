<Window x:Class="CodexSwitcher.Bootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Account Switcher"
        Width="520"
        Height="280"
        MinWidth="420"
        MinHeight="240"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF7F7F8">
        <Border Margin="32"
                Padding="28"
                Background="White"
                BorderBrush="#FFE2E2E5"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#FF202123"
                           Text="Codex Account Switcher" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="#FF6B6B70"
                           Text="Windows용 Codex 계정 전환 도구" />
                <Border Margin="0,28,0,0"
                        Padding="16"
                        Background="#FFF3F3F5"
                        CornerRadius="8">
                    <TextBlock AutomationProperties.Name="{Binding InstallationStatusMessage}"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="#FF303033"
                               Text="{Binding InstallationStatusMessage}" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>

