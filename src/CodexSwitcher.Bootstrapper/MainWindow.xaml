<Window x:Class="CodexSwitcher.Bootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Account Switcher"
        Width="660"
        Height="700"
        MinWidth="560"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Background="#FFF7F7F8">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Border Margin="24"
                    Padding="24"
                    Background="White"
                    BorderBrush="#FFE2E2E5"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#FF202123"
                                   Text="Codex Account Switcher" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="#FF6B6B70"
                                   Text="Windows용 Codex 계정 전환 도구" />
                        <Border Margin="0,20,0,0"
                                Padding="14"
                                Background="#FFF3F3F5"
                                CornerRadius="8">
                            <TextBlock AutomationProperties.Name="{Binding InstallationStatusMessage}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#FF303033"
                                       Text="{Binding InstallationStatusMessage}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <Border Margin="0,8,0,0"
                                Padding="14"
                                Background="#FFEAF3FF"
                                CornerRadius="8">
                            <TextBlock AutomationProperties.Name="{Binding RuntimeStatusMessage}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#FF264B72"
                                       Text="{Binding RuntimeStatusMessage}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Margin="2,8,2,0"
                                   AutomationProperties.Name="{Binding OperationStatusMessage}"
                                   Foreground="#FF6B4B20"
                                   Text="{Binding OperationStatusMessage}"
                                   TextWrapping="Wrap" />
                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="#FFFFF4DE"
                                CornerRadius="8"
                                Visibility="{Binding HasPendingRecovery, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="완료되지 않은 로그인 작업이 있습니다." />
                                <TextBlock Margin="0,4,0,10"
                                           TextWrapping="Wrap"
                                           Text="새 프로필을 추가하기 전에 이전 인증 상태를 복구해야 합니다." />
                                <Button x:Name="RecoveryButton"
                                        MinWidth="190"
                                        HorizontalAlignment="Left"
                                        Click="RecoverPreviousLogin_Click"
                                        Content="이전 로그인 작업 복구" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <Button DockPanel.Dock="Right"
                                    AutomationProperties.Name="새 프로필 추가"
                                    MinWidth="116"
                                    Padding="14,7"
                                    Click="AddProfile_Click"
                                    IsEnabled="{Binding CanAddProfile}"
                                    Content="새 프로필 추가" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="프로필" />
                        </DockPanel>
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,10"
                                   AutomationProperties.Name="{Binding ProfileStatusMessage}"
                                   Foreground="#FF6B6B70"
                                   Text="{Binding ProfileStatusMessage}"
                                   TextWrapping="Wrap" />
                        <ListBox Grid.Row="2"
                                 AutomationProperties.Name="프로필 목록"
                                 MinHeight="220"
                                 MaxHeight="340"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemsSource="{Binding Profiles}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2"
                                            Padding="10"
                                            CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}"
                                                                 Value="True">
                                                        <Setter Property="Background"
                                                                Value="#FFE8F5EA" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel>
                                            <Menu DockPanel.Dock="Right"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent">
                                                <MenuItem Padding="10,5"
                                                          AutomationProperties.Name="프로필 관리 메뉴"
                                                          Header="관리">
                                                    <MenuItem Header="삭제"
                                                              AutomationProperties.Name="프로필 삭제"
                                                              Click="DeleteProfile_Click"
                                                              CommandParameter="{Binding}"
                                                              IsEnabled="{Binding IsDeleteEnabled}" />
                                                </MenuItem>
                                            </Menu>
                                            <Button DockPanel.Dock="Right"
                                                    AutomationProperties.Name="{Binding ButtonText}"
                                                    MinWidth="76"
                                                    Padding="12,5"
                                                    Click="RunProfile_Click"
                                                    IsEnabled="{Binding IsRunEnabled}"
                                                    Content="{Binding ButtonText}" />
                                            <StackPanel>
                                                <TextBlock FontSize="15"
                                                           FontWeight="Medium"
                                                           Text="{Binding Name}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="#FF3A7A44"
                                                           Text="{Binding Status}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
