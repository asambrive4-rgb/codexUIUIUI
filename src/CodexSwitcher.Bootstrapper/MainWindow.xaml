<ui:FluentWindow x:Class="CodexSwitcher.Bootstrapper.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Codex Account Switcher"
                 Width="450"
                 Height="500"
                 MinWidth="400"
                 MinHeight="400"
                 Background="{DynamicResource AppBrush.WindowBackground}"
                 ExtendsContentIntoTitleBar="True"
                 Icon="Assets/codexUIUIUI.ico"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Profile Card Template -->
        <DataTemplate x:Key="ProfileCardTemplate">
            <Border Padding="12,10"
                    BorderThickness="1"
                    CornerRadius="12"
                    Background="{DynamicResource AppBrush.Surface}"
                    BorderBrush="{DynamicResource AppBrush.Border}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource AppBrush.Surface}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBrush.Border}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppBrush.AccentMuted}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AppBrush.Accent}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF8A3D"
                                                          BlurRadius="12"
                                                          ShadowDepth="1"
                                                          Opacity="0.08"
                                                          Direction="270"
                                                          RenderingBias="Performance" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Area: Information & Usage Progress -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <!-- Profile Name -->
                        <TextBlock FontSize="13.5"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBrush.Text}"
                                   Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="150"
                                   Margin="0,0,0,3" />

                        <!-- Status Badge -->
                        <Border Margin="0,0,0,8"
                                Padding="6,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppBrush.PillSurface}"
                                CornerRadius="4">
                            <TextBlock FontSize="9.5"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppBrush.SuccessText}"
                                       Text="{Binding Status}" />
                        </Border>

                        <!-- Usage Rates (DockPanel based layout to completely prevent overlapping) -->
                        <StackPanel Margin="0,2,0,0" Visibility="{Binding HasUsageData, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- 5 Hour Usage -->
                            <StackPanel Margin="0,0,0,6">
                                <DockPanel LastChildFill="True" Margin="0,0,0,3">
                                    <!-- Right aligned Value & Reset Time -->
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="4,0,0,0">
                                        <TextBlock FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding FiveHourUsage.ProgressBrush}"
                                                   Text="{Binding FiveHourUsage.RemainingPercent, StringFormat={}{0}%}"
                                                   Margin="0,0,3,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9"
                                                   Foreground="{DynamicResource AppBrush.TextMuted}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding FiveHourUsage.ResetTimeText, StringFormat={} ({0})}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Text" Value="정보 없음" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Left aligned Label (takes remaining space and ellipsizes if too narrow) -->
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBrush.Text}"
                                               Text="{Binding FiveHourUsage.Label}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                
                                <ProgressBar Style="{StaticResource ModernProgressBarStyle}"
                                             Maximum="100"
                                             Foreground="{Binding FiveHourUsage.ProgressBrush}"
                                             IsHitTestVisible="False"
                                             Value="{Binding FiveHourUsage.RemainingPercent, Mode=OneWay}" />
                            </StackPanel>

                            <!-- Weekly Usage -->
                            <StackPanel Margin="0,0,0,2">
                                <DockPanel LastChildFill="True" Margin="0,0,0,3">
                                    <!-- Right aligned Value & Reset Time -->
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="4,0,0,0">
                                        <TextBlock FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WeeklyUsage.ProgressBrush}"
                                                   Text="{Binding WeeklyUsage.RemainingPercent, StringFormat={}{0}%}"
                                                   Margin="0,0,3,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9"
                                                   Foreground="{DynamicResource AppBrush.TextMuted}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding WeeklyUsage.ResetTimeText, StringFormat={} ({0})}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Text" Value="정보 없음" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Left aligned Label (takes remaining space and ellipsizes if too narrow) -->
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBrush.Text}"
                                               Text="{Binding WeeklyUsage.Label}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                
                                <ProgressBar Style="{StaticResource ModernProgressBarStyle}"
                                             Maximum="100"
                                             Foreground="{Binding WeeklyUsage.ProgressBrush}"
                                             IsHitTestVisible="False"
                                             Value="{Binding WeeklyUsage.RemainingPercent, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Usage status description message -->
                        <TextBlock Margin="0,4,0,0"
                                   AutomationProperties.Name="{Binding UsageStatusMessage}"
                                   FontSize="9.5"
                                   Foreground="{DynamicResource AppBrush.TextMuted}"
                                   Text="{Binding UsageStatusMessage}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasUsageStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Right Area: Control Actions (Run CTA & Settings) -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                Margin="10,0,0,0"
                                Width="52">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.Name="{Binding ButtonText}"
                                Click="RunProfile_Click"
                                IsEnabled="{Binding IsRunEnabled}"
                                Content="{Binding ButtonText}"
                                Height="28"
                                MinHeight="28"
                                Padding="0"
                                FontSize="11"
                                HorizontalAlignment="Stretch" />

                        <ui:Button Margin="0,8,0,0"
                                   Appearance="Secondary"
                                   Click="ManageButton_Click"
                                   Height="26"
                                   MinHeight="26"
                                   Padding="0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Width="26">
                            <ui:Button.ContextMenu>
                                <ContextMenu x:Name="ProfileContextMenu" 
                                             DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="삭제"
                                              Click="DeleteProfile_Click"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding IsDeleteEnabled}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#FFDC2626" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ui:Button.ContextMenu>
                            <ui:SymbolIcon Symbol="Settings24" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource AppBrush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Height="48"
                     Background="{DynamicResource AppBrush.TitleBar}">
            <ui:TitleBar.Header>
                <StackPanel Margin="16,0,0,0"
                            Orientation="Horizontal">
                    <Image Width="20"
                           Height="20"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Source="Assets/codexUIUIUI.png" />
                    <TextBlock Style="{StaticResource TitleBarCaptionTextStyle}"
                               Text="Codex Account Switcher" />
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.CenterContent>
                <Border MaxWidth="310"
                        Padding="10,5"
                        Background="{DynamicResource AppBrush.InfoSurface}"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6"
                                 Height="6"
                                 Margin="0,0,6,0"
                                 Fill="{DynamicResource AppBrush.Accent}" />
                        <TextBlock AutomationProperties.Name="{Binding RuntimeStatusMessage}"
                                   MaxWidth="260"
                                   Style="{StaticResource TitleBarStatusTextStyle}"
                                   Text="{Binding RuntimeStatusMessage}" />
                    </StackPanel>
                </Border>
            </ui:TitleBar.CenterContent>
        </ui:TitleBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- 0: Recovery / Warning Panel -->
                <RowDefinition Height="Auto" /> <!-- 1: Profiles Header -->
                <RowDefinition Height="*" />    <!-- 2: Scrollable Profiles list (Fills remaining height) -->
            </Grid.RowDefinitions>

            <!-- Recovery & Warning Panel -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Margin="2,0,2,0"
                           AutomationProperties.Name="{Binding OperationStatusMessage}"
                           Foreground="{DynamicResource AppBrush.WarningText}"
                           Text="{Binding OperationStatusMessage}"
                           TextWrapping="Wrap" />
                <Border Margin="0,10,0,0"
                        Style="{StaticResource StatusPanelStyle}"
                        Background="{DynamicResource AppBrush.WarningSurface}"
                        Visibility="{Binding HasPendingRecovery, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="{DynamicResource AppBrush.WarningText}"
                                   Text="완료되지 않은 로그인 작업이 있습니다." />
                        <TextBlock Margin="0,4,0,10"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource AppBrush.WarningText}"
                                   Text="새 프로필을 추가하기 전에 이전 인증 상태를 복구해야 합니다."
                                   TextWrapping="Wrap" />
                        <Button x:Name="RecoveryButton"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="180"
                                Height="32"
                                MinHeight="32"
                                HorizontalAlignment="Left"
                                Click="RecoverPreviousLogin_Click"
                                Content="이전 로그인 작업 복구" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Profiles Header Area -->
            <Grid Grid.Row="1" Margin="0,4,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="프로필"
                               VerticalAlignment="Center" />
                    <Border Margin="8,0,0,0"
                            Padding="8,2"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AppBrush.PillSurface}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InstallationStatusMessage}" Value="설치됨">
                                        <Setter Property="Background" Value="{DynamicResource AppBrush.SuccessSurface}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AppBrush.SuccessBorder}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding InstallationStatusMessage}" Value="미설치">
                                        <Setter Property="Background" Value="{DynamicResource AppBrush.WarningSurface}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AppBrush.WarningText}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppBrush.TextMuted}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InstallationStatusMessage}" Value="설치됨">
                                            <Setter Property="Foreground" Value="{DynamicResource AppBrush.SuccessText}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InstallationStatusMessage}" Value="미설치">
                                            <Setter Property="Foreground" Value="{DynamicResource AppBrush.WarningText}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="InstallationStatusMessage" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>
                
                <!-- Header Control Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Appearance="Secondary"
                               Margin="0,0,8,0"
                               Padding="10,5"
                               Height="30"
                               AutomationProperties.Name="사용량 새로고침"
                               Click="UsageRefresh_Click"
                               IsEnabled="{Binding CanRefreshUsage}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                            <TextBlock Text="새로고침" VerticalAlignment="Center" FontSize="11.5" />
                        </StackPanel>
                    </ui:Button>

                    <Button Style="{StaticResource AccentButtonStyle}"
                            AutomationProperties.Name="새 프로필 추가"
                            Click="AddProfile_Click"
                            IsEnabled="{Binding CanAddProfile}"
                            Height="30"
                            MinHeight="30"
                            Padding="12,0"
                            FontSize="11.5">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Add24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                            <TextBlock Text="프로필 추가" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Scrollable Profiles list (Occupies the rest of window height dynamically) -->
            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,2,0,0">
                <StackPanel>
                    <!-- 1. Active Profile Area -->
                    <StackPanel Visibility="{Binding HasActiveProfile, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="실행 중인 프로필"
                                   Margin="2,0,0,6" />
                        <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                            <ContentControl Content="{Binding ActiveProfile}"
                                            ContentTemplate="{StaticResource ProfileCardTemplate}"
                                            Margin="0,3,6,3" />
                        </UniformGrid>
                    </StackPanel>

                    <!-- 2. Registered Profiles Area -->
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="등록된 프로필"
                                   Margin="2,4,0,6" />
                        <ListBox AutomationProperties.Name="프로필 목록"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemsSource="{Binding InactiveProfiles}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  Margin="{TemplateBinding Padding}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}"
                                                    ContentTemplate="{StaticResource ProfileCardTemplate}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
