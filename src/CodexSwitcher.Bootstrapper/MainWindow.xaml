<ui:FluentWindow x:Class="CodexSwitcher.Bootstrapper.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Codex Account Switcher"
                 Width="720"
                 Height="720"
                 MinWidth="600"
                 MinHeight="580"
                 Background="{DynamicResource AppBrush.WindowBackground}"
                 ExtendsContentIntoTitleBar="True"
                 Icon="Assets/codexUIUIUI.ico"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid Background="{DynamicResource AppBrush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="48"
                     Background="{DynamicResource AppBrush.TitleBar}">
            <ui:TitleBar.Header>
                <StackPanel Margin="16,0,0,0"
                            Orientation="Horizontal">
                    <Image Width="22"
                           Height="22"
                           Margin="0,0,9,0"
                           VerticalAlignment="Center"
                           Source="Assets/codexUIUIUI.png" />
                    <TextBlock Style="{StaticResource TitleBarCaptionTextStyle}"
                               Text="Codex Account Switcher" />
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.CenterContent>
                <Border MaxWidth="310"
                        Padding="10,5"
                        Background="{DynamicResource AppBrush.InfoSurface}"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,7,0"
                                 Fill="{DynamicResource AppBrush.Accent}" />
                        <TextBlock AutomationProperties.Name="{Binding RuntimeStatusMessage}"
                                   MaxWidth="260"
                                   Style="{StaticResource TitleBarStatusTextStyle}"
                                   Text="{Binding RuntimeStatusMessage}" />
                    </StackPanel>
                </Border>
            </ui:TitleBar.CenterContent>
            <ui:TitleBar.TrailingContent>
                <Button Margin="0,0,12,0"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.Name="새 프로필 추가"
                        MinWidth="118"
                        MinHeight="32"
                        Padding="14,5"
                        Click="AddProfile_Click"
                        IsEnabled="{Binding CanAddProfile}"
                        Content="새 프로필 추가" />
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="28,18,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,0">
                    <TextBlock Margin="2,0,2,0"
                               AutomationProperties.Name="{Binding OperationStatusMessage}"
                               Foreground="{DynamicResource AppBrush.WarningText}"
                               Text="{Binding OperationStatusMessage}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,12,0,0"
                            Style="{StaticResource StatusPanelStyle}"
                            Background="{DynamicResource AppBrush.WarningSurface}"
                            Visibility="{Binding HasPendingRecovery, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBrush.WarningText}"
                                       Text="완료되지 않은 로그인 작업이 있습니다." />
                            <TextBlock Margin="0,5,0,12"
                                       Foreground="{DynamicResource AppBrush.WarningText}"
                                       Text="새 프로필을 추가하기 전에 이전 인증 상태를 복구해야 합니다."
                                       TextWrapping="Wrap" />
                            <Button x:Name="RecoveryButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    MinWidth="190"
                                    MinHeight="34"
                                    HorizontalAlignment="Left"
                                    Click="RecoverPreviousLogin_Click"
                                    Content="이전 로그인 작업 복구" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="프로필"
                                       VerticalAlignment="Center" />
                            <Border Margin="10,0,0,0"
                                    Padding="8,3"
                                    CornerRadius="10"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource AppBrush.PillSurface}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                         Value="설치됨">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AppBrush.SuccessSurface}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AppBrush.SuccessBorder}" />
                                                <Setter Property="BorderThickness"
                                                        Value="1" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                         Value="미설치">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AppBrush.WarningSurface}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AppBrush.WarningText}" />
                                                <Setter Property="BorderThickness"
                                                        Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource AppBrush.TextMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                             Value="설치됨">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource AppBrush.SuccessText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                             Value="미설치">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource AppBrush.WarningText}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="InstallationStatusMessage" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="104"
                                MinHeight="32"
                                Padding="12,4"
                                AutomationProperties.Name="전체 계정 사용량 새로고침"
                                Click="UsageRefresh_Click"
                                Content="사용량 새로고침"
                                IsEnabled="{Binding CanRefreshUsage}" />
                    </Grid>
                    <ListBox Grid.Row="1"
                             AutomationProperties.Name="프로필 목록"
                             MinHeight="240"
                             MaxHeight="360"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemsSource="{Binding Profiles}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                                <Setter Property="Padding"
                                        Value="0" />
                                <Setter Property="Margin"
                                        Value="4" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16"
                                        BorderBrush="{DynamicResource AppBrush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Background="{DynamicResource AppBrush.Surface}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource AppBrush.Surface}" />
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource AppBrush.Border}" />
                                            <Setter Property="BorderThickness"
                                                    Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource AppBrush.SuccessSurface}" />
                                                    <Setter Property="BorderBrush"
                                                            Value="{DynamicResource AppBrush.SuccessBorder}" />
                                                    <Setter Property="BorderThickness"
                                                            Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,0,0,10">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppBrush.Text}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Margin="0,6,0,0"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource AppBrush.PillSurface}"
                                                    CornerRadius="6">
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppBrush.SuccessText}"
                                                           Text="{Binding Status}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>

                                        <Button Grid.Row="1"
                                                Grid.Column="0"
                                                Style="{StaticResource AccentButtonStyle}"
                                                AutomationProperties.Name="{Binding ButtonText}"
                                                HorizontalAlignment="Stretch"
                                                MinHeight="32"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Click="RunProfile_Click"
                                                IsEnabled="{Binding IsRunEnabled}"
                                                Content="{Binding ButtonText}" />

                                        <Menu Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Background="Transparent">
                                            <MenuItem Padding="8,4"
                                                      AutomationProperties.Name="프로필 관리 메뉴"
                                                      Header="관리">
                                                <MenuItem Header="삭제"
                                                          AutomationProperties.Name="프로필 삭제"
                                                          Click="DeleteProfile_Click"
                                                          CommandParameter="{Binding}"
                                                          IsEnabled="{Binding IsDeleteEnabled}" />
                                            </MenuItem>
                                        </Menu>

                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,12,0,0">
                                            <StackPanel Visibility="{Binding HasUsageData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock AutomationProperties.Name="{Binding FiveHourUsage.AutomationName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AppBrush.TextMuted}"
                                                           Text="{Binding FiveHourUsage.DisplayText}" />
                                                <ProgressBar Height="4"
                                                             Margin="0,4,0,8"
                                                             Maximum="100"
                                                             Background="{DynamicResource AppBrush.SurfaceMuted}"
                                                             BorderThickness="0"
                                                             Foreground="{Binding FiveHourUsage.ProgressBrush}"
                                                             IsHitTestVisible="False"
                                                             Value="{Binding FiveHourUsage.RemainingPercent, Mode=OneWay}" />
                                                <TextBlock AutomationProperties.Name="{Binding WeeklyUsage.AutomationName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AppBrush.TextMuted}"
                                                           Text="{Binding WeeklyUsage.DisplayText}" />
                                                <ProgressBar Height="4"
                                                             Margin="0,4,0,0"
                                                             Maximum="100"
                                                             Background="{DynamicResource AppBrush.SurfaceMuted}"
                                                             BorderThickness="0"
                                                             Foreground="{Binding WeeklyUsage.ProgressBrush}"
                                                             IsHitTestVisible="False"
                                                             Value="{Binding WeeklyUsage.RemainingPercent, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock Margin="0,6,0,0"
                                                       AutomationProperties.Name="{Binding UsageStatusMessage}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource AppBrush.TextMuted}"
                                                       Text="{Binding UsageStatusMessage}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasUsageStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
