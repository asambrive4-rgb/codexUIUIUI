<ui:FluentWindow x:Class="CodexSwitcher.Bootstrapper.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Codex Account Switcher"
                 Width="450"
                 Height="500"
                 MinWidth="400"
                 MinHeight="400"
                 Background="{DynamicResource AppBrush.WindowBackground}"
                 ExtendsContentIntoTitleBar="True"
                 Icon="Assets/codexUIUIUI.ico"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate x:Key="ProfileCardTemplate">
            <Border Padding="12,12"
                    BorderThickness="0"
                    CornerRadius="12"
                    Background="{DynamicResource AppBrush.Surface}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"
                                Value="{DynamicResource AppBrush.Surface}" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource AppBrush.AccentMuted}" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000"
                                                          BlurRadius="16"
                                                          ShadowDepth="1"
                                                          Opacity="0.06"
                                                          Direction="270"
                                                          RenderingBias="Performance" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Info & Usage Stack (Vertical Stack) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <!-- Name Block -->
                        <TextBlock FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBrush.Text}"
                                   Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="120"
                                   Margin="0,0,0,2" />

                        <!-- Status Badge -->
                        <Border Margin="0,0,0,8"
                                Padding="5,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppBrush.PillSurface}"
                                CornerRadius="4">
                            <TextBlock FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBrush.SuccessText}"
                                       Text="{Binding Status}" />
                        </Border>

                        <!-- Usage stack -->
                        <StackPanel Margin="0,2,0,0" Visibility="{Binding HasUsageData, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- 5 Hour Usage Stacked -->
                            <StackPanel Margin="0,0,0,8">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left: Label -->
                                    <TextBlock Grid.Column="0"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBrush.Text}"
                                               Text="{Binding FiveHourUsage.Label}"
                                               VerticalAlignment="Center" />
                                    
                                    <!-- Right: Value + Reset Time -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding FiveHourUsage.ProgressBrush}"
                                                   Text="{Binding FiveHourUsage.RemainingPercent, StringFormat={}{0}%}"
                                                   Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9.5"
                                                   Foreground="{DynamicResource AppBrush.TextMuted}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding FiveHourUsage.ResetTimeText, StringFormat={} ({0})}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FiveHourUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Text" Value="정보 없음" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                
                                <Border CornerRadius="3"
                                        ClipToBounds="True"
                                        Height="6"
                                        Background="{DynamicResource AppBrush.SurfaceMuted}">
                                    <ProgressBar Height="6"
                                                 Maximum="100"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{Binding FiveHourUsage.ProgressBrush}"
                                                 IsHitTestVisible="False"
                                                 Value="{Binding FiveHourUsage.RemainingPercent, Mode=OneWay}" />
                                </Border>
                            </StackPanel>

                            <!-- Weekly Usage Stacked -->
                            <StackPanel Margin="0,0,0,2">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left: Label -->
                                    <TextBlock Grid.Column="0"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBrush.Text}"
                                               Text="{Binding WeeklyUsage.Label}"
                                               VerticalAlignment="Center" />
                                    
                                    <!-- Right: Value + Reset Time -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding WeeklyUsage.ProgressBrush}"
                                                   Text="{Binding WeeklyUsage.RemainingPercent, StringFormat={}{0}%}"
                                                   Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9.5"
                                                   Foreground="{DynamicResource AppBrush.TextMuted}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding WeeklyUsage.ResetTimeText, StringFormat={} ({0})}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeeklyUsage.IsDataAvailable}" Value="False">
                                                            <Setter Property="Text" Value="정보 없음" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                
                                <Border CornerRadius="3"
                                        ClipToBounds="True"
                                        Height="6"
                                        Background="{DynamicResource AppBrush.SurfaceMuted}">
                                    <ProgressBar Height="6"
                                                 Maximum="100"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{Binding WeeklyUsage.ProgressBrush}"
                                                 IsHitTestVisible="False"
                                                 Value="{Binding WeeklyUsage.RemainingPercent, Mode=OneWay}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Margin="0,3,0,0"
                                   AutomationProperties.Name="{Binding UsageStatusMessage}"
                                   FontSize="9"
                                   Foreground="{DynamicResource AppBrush.TextMuted}"
                                   Text="{Binding UsageStatusMessage}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasUsageStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Right: Control Buttons (Vertical Stack to save width) -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                Margin="8,0,0,0">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.Name="{Binding ButtonText}"
                                Click="RunProfile_Click"
                                IsEnabled="{Binding IsRunEnabled}"
                                Content="{Binding ButtonText}"
                                MinWidth="48"
                                MinHeight="26"
                                Padding="5,4"
                                FontSize="11"
                                HorizontalAlignment="Stretch" />

                        <ui:Button Margin="0,6,0,0"
                                   Appearance="Secondary"
                                   Click="ManageButton_Click"
                                   MinWidth="26"
                                   MinHeight="26"
                                   Padding="0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <ui:Button.ContextMenu>
                                <ContextMenu x:Name="ProfileContextMenu" 
                                             DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="삭제"
                                              Click="DeleteProfile_Click"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding IsDeleteEnabled}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#FFEF4444" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ui:Button.ContextMenu>
                            <ui:SymbolIcon Symbol="Settings24" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>
    <Grid Background="{DynamicResource AppBrush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="48"
                     Background="{DynamicResource AppBrush.TitleBar}">
            <ui:TitleBar.Header>
                <StackPanel Margin="16,0,0,0"
                            Orientation="Horizontal">
                    <Image Width="22"
                           Height="22"
                           Margin="0,0,9,0"
                           VerticalAlignment="Center"
                           Source="Assets/codexUIUIUI.png" />
                    <TextBlock Style="{StaticResource TitleBarCaptionTextStyle}"
                               Text="Codex Account Switcher" />
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.CenterContent>
                <Border MaxWidth="310"
                        Padding="10,5"
                        Background="{DynamicResource AppBrush.InfoSurface}"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,7,0"
                                 Fill="{DynamicResource AppBrush.Accent}" />
                        <TextBlock AutomationProperties.Name="{Binding RuntimeStatusMessage}"
                                   MaxWidth="260"
                                   Style="{StaticResource TitleBarStatusTextStyle}"
                                   Text="{Binding RuntimeStatusMessage}" />
                    </StackPanel>
                </Border>
            </ui:TitleBar.CenterContent>

        </ui:TitleBar>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,0">
                    <TextBlock Margin="2,0,2,0"
                               AutomationProperties.Name="{Binding OperationStatusMessage}"
                               Foreground="{DynamicResource AppBrush.WarningText}"
                               Text="{Binding OperationStatusMessage}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,12,0,0"
                            Style="{StaticResource StatusPanelStyle}"
                            Background="{DynamicResource AppBrush.WarningSurface}"
                            Visibility="{Binding HasPendingRecovery, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBrush.WarningText}"
                                       Text="완료되지 않은 로그인 작업이 있습니다." />
                            <TextBlock Margin="0,5,0,12"
                                       Foreground="{DynamicResource AppBrush.WarningText}"
                                       Text="새 프로필을 추가하기 전에 이전 인증 상태를 복구해야 합니다."
                                       TextWrapping="Wrap" />
                            <Button x:Name="RecoveryButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    MinWidth="190"
                                    MinHeight="34"
                                    HorizontalAlignment="Left"
                                    Click="RecoverPreviousLogin_Click"
                                    Content="이전 로그인 작업 복구" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="프로필"
                                       VerticalAlignment="Center" />
                            <Border Margin="10,0,0,0"
                                    Padding="8,3"
                                    CornerRadius="10"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource AppBrush.PillSurface}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                         Value="설치됨">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AppBrush.SuccessSurface}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AppBrush.SuccessBorder}" />
                                                <Setter Property="BorderThickness"
                                                        Value="1" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                         Value="미설치">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AppBrush.WarningSurface}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AppBrush.WarningText}" />
                                                <Setter Property="BorderThickness"
                                                        Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource AppBrush.TextMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                             Value="설치됨">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource AppBrush.SuccessText}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InstallationStatusMessage}"
                                                             Value="미설치">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource AppBrush.WarningText}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="InstallationStatusMessage" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Appearance="Secondary"
                                       Margin="0,0,8,0"
                                       Padding="10,5"
                                       AutomationProperties.Name="사용량 새로고침"
                                       Click="UsageRefresh_Click"
                                       IsEnabled="{Binding CanRefreshUsage}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowClockwise24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="14" />
                                    <TextBlock Text="새로고침" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </ui:Button>

                            <Button Style="{StaticResource AccentButtonStyle}"
                                    AutomationProperties.Name="새 프로필 추가"
                                    Click="AddProfile_Click"
                                    IsEnabled="{Binding CanAddProfile}"
                                    MinHeight="30"
                                    Padding="12,6"
                                    FontSize="12">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="14" />
                                    <TextBlock Text="프로필 추가" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                        <!-- 1. 활성화된(실행중인) 프로필 카드 영역 (활성화 시에만 노출) -->
                        <StackPanel Visibility="{Binding HasActiveProfile, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="실행 중인 프로필"
                                       Margin="2,0,0,6" />
                            <!-- 단일 활성화 프로필 렌더링 (하단 카드 목록과 가로 폭 및 여백을 일치시키기 위해 2열 UniformGrid에 배치) -->
                            <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                                <ContentControl Content="{Binding ActiveProfile}"
                                                ContentTemplate="{StaticResource ProfileCardTemplate}"
                                                Margin="6" />
                            </UniformGrid>
                        </StackPanel>

                        <!-- 2. 등록된 프로필 목록 영역 -->
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="등록된 프로필"
                                       Margin="2,8,0,8" />
                            <ListBox AutomationProperties.Name="프로필 목록"
                                     MinHeight="120"
                                     MaxHeight="310"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ItemsSource="{Binding InactiveProfiles}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" IsItemsHost="True" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch" />
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="Margin"
                                                Value="3" />
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      Margin="{TemplateBinding Padding}" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding}"
                                                        ContentTemplate="{StaticResource ProfileCardTemplate}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
