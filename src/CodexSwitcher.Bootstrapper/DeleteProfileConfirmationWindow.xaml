<ui:FluentWindow x:Class="CodexSwitcher.Bootstrapper.DeleteProfileConfirmationWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="프로필 삭제"
                 Width="520"
                 MinWidth="460"
                 MinHeight="280"
                 ResizeMode="NoResize"
                 SizeToContent="Height"
                 Background="{DynamicResource AppBrush.WindowBackground}"
                 ExtendsContentIntoTitleBar="True"
                 Icon="Assets/codexUIUIUI.ico"
                 WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource AppBrush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="46"
                     Background="{DynamicResource AppBrush.TitleBar}"
                     ShowMaximize="False">
            <ui:TitleBar.Header>
                <StackPanel Margin="16,0,0,0"
                            Orientation="Horizontal">
                    <Image Width="20"
                           Height="20"
                           Margin="0,0,9,0"
                           VerticalAlignment="Center"
                           Source="Assets/codexUIUIUI.png" />
                    <TextBlock Style="{StaticResource TitleBarCaptionTextStyle}"
                               Text="프로필 삭제" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1"
              Margin="26,18,26,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource SectionTitleTextStyle}"
                       Text="{Binding TitleText}"
                       TextWrapping="Wrap" />
            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Style="{StaticResource StatusPanelStyle}"
                    Background="{DynamicResource AppBrush.WarningSurface}">
                <TextBlock FontSize="14"
                           Foreground="{DynamicResource AppBrush.WarningText}"
                           Text="이 프로필에 저장된 Codex 로그인 정보가 삭제됩니다. 공통 Codex 작업 데이터와 설정은 삭제되지 않습니다. 로그인 정보 삭제는 되돌릴 수 없습니다."
                           TextWrapping="Wrap" />
            </Border>
            <StackPanel Grid.Row="2"
                        Margin="0,22,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="84"
                        MinHeight="34"
                        AutomationProperties.Name="삭제 취소"
                        Padding="12,6"
                        Click="Cancel_Click"
                        Content="취소"
                        IsCancel="True" />
                <Button Style="{StaticResource DangerButtonStyle}"
                        MinWidth="220"
                        MinHeight="34"
                        AutomationProperties.Name="프로필 및 로그인 정보 삭제"
                        Margin="8,0,0,0"
                        Padding="12,6"
                        Click="Delete_Click"
                        Content="프로필 및 로그인 정보 삭제"
                        IsDefault="False" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
